{
  "family": "rrelayer-prod",
  "taskRoleArn": "arn:aws:iam::314429810762:role/rrelayer-prod-task-role",
  "executionRoleArn": "arn:aws:iam::314429810762:role/rrelayer-prod-task-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "rrelayer-prod",
      "image": "314429810762.dkr.ecr.ap-northeast-1.amazonaws.com/rrelayer-prod:2633f790adcb671b35839a2c29c815dce81aaf8c",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "ap-northeast-1"
        },
        {
          "name": "RUST_LOG",
          "value": "info"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:314429810762:secret:rrelayer/prod/database-url-KdvnD5"
        },
        {
          "name": "RRELAYER_AUTH_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:314429810762:secret:rrelayer/prod/auth-username-BZLavP"
        },
        {
          "name": "RRELAYER_AUTH_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:314429810762:secret:rrelayer/prod/auth-password-G2IAa1"
        },
        {
          "name": "RRELAYER_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:314429810762:secret:rrelayer/prod/private-key-Mua84b"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:3000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rrelayer-prod",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
